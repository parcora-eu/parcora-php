{
    "name": "parcora/parcora-php",
    "description": "PHP SDK for the Parcora shipping API.",
    "type": "library",
    "keywords": ["parcora", "shipping", "parcels", "carriers", "sdk", "api"],
    "homepage": "https://parcora.eu",
    "license": "MIT",
    "authors": [
        { "name": "Parcora", "homepage": "https://parcora.eu" }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "laravel/pint": "^1.18",
        "pestphp/pest": "^3.5",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "A PSR-18 HTTP client implementation (any PSR-18 client works)."
    },
    "autoload": {
        "psr-4": { "Parcora\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Parcora\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse",
        "lint": "pint --test",
        "fix": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
